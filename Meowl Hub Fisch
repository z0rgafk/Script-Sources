local function optimizePart(obj)

	if not obj:IsA("BasePart") then return end

	if AntiLagMethods.AntiLagColor then

		applyTheme(obj)

	end

	if AntiLagMethods.NoShadows then

		obj.CastShadow = false

	end

end

local function optimizeCharacter(char)

	if AntiLagMethods.Accessories then

		for _, v in ipairs(char:GetChildren()) do

			if v:IsA("Accessory") then

				v:Destroy()

			end

		end

	end

	if AntiLagMethods.DisableClothes then

		for _, v in ipairs(char:GetChildren()) do

			if v:IsA("Shirt") or v:IsA("Pants") then

				v:Destroy()

			end

		end

	end

	if AntiLagMethods.NoPlayers then

		for _, v in ipairs(char:GetDescendants()) do

			if v:IsA("BasePart") then

				v.Transparency = 1

			end

		end

	end

end

