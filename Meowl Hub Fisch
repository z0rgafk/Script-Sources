local TweenService = game:GetService("TweenService")

local Players = game:GetService("Players")

local UserInputService = game:GetService("UserInputService")

--// Settings

local checkInterval = 0.01

local tweenTime = 0.001

local refreshDelay = 0.01

local offsetX = 0.05

local fishFollowEnabled = false

--// Function to move fish to playerbar

local function moveFishToPlayerBar()

    local player = Players.LocalPlayer

    local gui = player:FindFirstChild("PlayerGui")

    if not gui then return end

    local reel = gui:FindFirstChild("reel")

    if not reel then return end

    local bar = reel:FindFirstChild("bar")

    if not bar then return end

    local playerbar = bar:FindFirstChild("playerbar")

    if not playerbar then return end

    local fish = bar:FindFirstChild("fish")

    if not fish then return end

    local barPos = bar.AbsolutePosition

    local barSize = bar.AbsoluteSize

    local playerbarPos = playerbar.AbsolutePosition

    local relX = (playerbarPos.X - barPos.X) / barSize.X + offsetX

    local relY = (playerbarPos.Y - barPos.Y) / barSize.Y

    relX = math.clamp(relX, 0, 1)

    local targetPos = UDim2.new(relX, 0, relY, 0)

    local tween = TweenService:Create(fish, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {Position = targetPos})

    tween:Play()

end

--// Main loop

task.spawn(function()

    while true do

        if fishFollowEnabled then

            local endTime = tick() + refreshDelay

            while tick() < endTime do

                moveFishToPlayerBar()

                task.wait(checkInterval)

            end

        else

            task.wait(0.1)

        end

    end

end)

