		part.Color = Color3.fromRGB(255,255,255)

	elseif AntiLagColorMode == "USA" then

		local colors = {

			Color3.fromRGB(178,34,52),

			Color3.fromRGB(255,255,255),

			Color3.fromRGB(60,59,110)

		}

		part.Color = colors[math.random(1,#colors)]

	elseif AntiLagColorMode == "EUA" then

		-- fallback (renamed to USA but kept safe)

		part.Color = Color3.fromRGB(255,255,255)

	elseif AntiLagColorMode == "1900s" then

