    local tweenTime = math.clamp(distanceX + distanceY, 0.01, 0.1) / SlowFactor

    -- Cancela tween anterior

    if activeTween then

        activeTween:Cancel()

    end

    -- Tween para mover suavemente

    activeTween = TweenService:Create(

        fish,

        TweenInfo.new(tweenTime, Enum.EasingStyle.Linear),

        { Position = desiredPos }

    )

    activeTween:Play()

