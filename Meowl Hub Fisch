--------------------------------------------------

local ProgressSpeedEnabled = false

local PUSH_POWER = 0.019

local FIRE_AT = 1

local SAFE_SIZE = 0.2

--------------------------------------------------

-- INTERNAL STATE

--------------------------------------------------

local overlayBar = nil

local lastOriginalX = nil

local fired = false

local lastProgressRef = nil

local lastDirection = 0 -- -1 esquerda | 1 direita

local boosting = false

local boostCooldown = false

--------------------------------------------------

-- CREATE OVERLAY BAR

--------------------------------------------------

local function createOverlay(originalBar)

	if overlayBar then		overlayBar:Destroy()

	end

	overlayBar = Instance.new("Frame")

	overlayBar.Name = "OverlayProgress"

	overlayBar.AnchorPoint = Vector2.new(0, 0.5)

	overlayBar.Position = UDim2.new(0, 0, 0.5, 0)

	overlayBar.Size = UDim2.new(0, 0, originalBar.Size.Y.Scale, 0)

	overlayBar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)

	overlayBar.BorderSizePixel = 0

	overlayBar.ZIndex = originalBar.ZIndex + 10

	overlayBar.Parent = originalBar.Parent

	-- Reset states

	fired = false

	lastOriginalX = nil

	lastDirection = 0

	boosting = false

	boostCooldown = false

end

--------------------------------------------------

-- MAIN LOOP

--------------------------------------------------

RunService.RenderStepped:Connect(function()

	if not ProgressSpeedEnabled then return end

	local gui = player:FindFirstChild("PlayerGui")

	if not gui then return end

	local reel = gui:FindFirstChild("reel")

	if not reel then return end

	local barFrame = reel:FindFirstChild("bar")

	if not barFrame then return end

	local progress = barFrame:FindFirstChild("progress")

	if not progress then return end

	local originalBar = progress:FindFirstChild("bar")

	if not originalBar then return end

	-- New fishing session

	if progress ~= lastProgressRef then

		lastProgressRef = progress

		createOverlay(originalBar)

		return

	end

	local originalX = originalBar.Size.X.Scale

	-- Safe size (wait bar start)

	if originalX < SAFE_SIZE then

		lastOriginalX = originalX

		return

	end

	if not overlayBar or overlayBar.Parent ~= originalBar.Parent then

		createOverlay(originalBar)

		return

	end

	if not lastOriginalX then

		lastOriginalX = originalX

		return

	end

	local delta = originalX - lastOriginalX

	local direction = delta > 0 and 1 or delta < 0 and -1 or 0

	local overlayX = overlayBar.Size.X.Scale

	-- Direction changed → reset boost lock

	if direction ~= lastDirection then

		boosting = false

		boostCooldown = false

	end

	-- MOVING RIGHT → APPLY BOOST ONCE

	if direction == 1 then

		if not boosting and not boostCooldown then

			overlayX += PUSH_POWER

			boosting = true

			boostCooldown = true

			task.delay(0.05, function()

				boostCooldown = false

			end)

		end

	-- MOVING LEFT → FOLLOW NORMAL

	elseif direction == -1 then

		overlayX += delta

		boosting = false

	end

	overlayX = math.clamp(overlayX, 0, 1)

	overlayBar.Size = UDim2.new(

		overlayX,

		0,

		overlayBar.Size.Y.Scale,

		0

	)

	-- FINISH FISH

	if overlayX >= FIRE_AT and not fired then

		fired = true

		reelfinished:FireServer(100, true)

	end

	lastDirection = direction

	lastOriginalX = originalX

end)

