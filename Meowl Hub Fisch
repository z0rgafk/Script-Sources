    -- Absolute positions

    local fishPos = fish.AbsolutePosition

    local fishSize = fish.AbsoluteSize

    local pbPos = playerbar.AbsolutePosition

    local pbSize = playerbar.AbsoluteSize

    local fishLeft = fishPos.X

    local fishRight = fishPos.X + fishSize.X

    local pbLeft = pbPos.X

