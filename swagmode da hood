Vfly2:AddToggle('w', {
    Text = 'no',
    Default = false,
    Callback = function(v)
        Conf["Environment"]["VehicleEnv"] = v
        if v then
            local keys = {a = false, d = false, w = false, s = false}
            if not workspace.Vehicles:FindFirstChild(OWNER.Name) then return end
            local pos = Instance.new("BodyPosition", workspace.Vehicles[OWNER.Name])
            local gyro = Instance.new("BodyGyro", workspace.Vehicles[OWNER.Name])
            
            pos.maxForce = Vector3.new(math.huge, math.huge, math.huge)
            pos.position = workspace.Vehicles[OWNER.Name].Position + Vector3.new(0,0,0)
            gyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
            gyro.cframe = workspace.Vehicles[OWNER.Name].CFrame

            OWNER:GetMouse().KeyDown:Connect(function(key)
                if key == "w" then
                    keys.w = true
                elseif key == "s" then
                    keys.s = true
                elseif key == "a" then
                    keys.a = true
                elseif key == "d" then
                    keys.d = true
                end
            end)

            OWNER:GetMouse().KeyUp:Connect(function(key)
                if key == "w" then
                    keys.w = false
                elseif key == "s" then
                    keys.s = false
                elseif key == "a" then
                    keys.a = false
                elseif key == "d" then
                    keys.d = false
                end
            end)

            repeat task.wait()
                local new=gyro.cframe - gyro.cframe.p + pos.position
                if keys.w then
                    new = new + workspace.CurrentCamera.CoordinateFrame.lookVector * Conf["Value"]["Vehicle"]
                end
                if keys.s then
                    new = new - workspace.CurrentCamera.CoordinateFrame.lookVector * Conf["Value"]["Vehicle"]
                end
                if keys.d then
                    new = new * CFrame.new(Conf["Value"]["Vehicle"], 0, 0)
                end
                if keys.a then
                    new = new * CFrame.new(-Conf["Value"]["Vehicle"], 0, 0)
                end

                pos.position = new.p
                gyro.cframe = workspace.CurrentCamera.CoordinateFrame
            until not Conf["Environment"]["VehicleEnv"]
            
            if gyro then gyro:Destroy() end
            if pos then pos:Destroy() end
        else
            Conf["Environment"]["VehicleEnv"] = false
        end
    end
})

