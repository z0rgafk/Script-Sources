function HiddenBullet()
    if OWNER.Character:FindFirstChildWhichIsA("Tool") and 
       OWNER.Character:FindFirstChildWhichIsA("Tool"):FindFirstChild("Handle") and 
       KO(Conf["Connection"]["TARGET"]).Value == false and 
       Dead(Conf["Connection"]["TARGET"]).Value == false then 

        local gunHandle = OWNER.Character:FindFirstChildWhichIsA("Tool"):FindFirstChild("Handle")
        local targetHead = Conf["Connection"]["TARGET"].Character:FindFirstChild("Head")
        local targetHRP = Conf["Connection"]["TARGET"].Character:FindFirstChild("HumanoidRootPart")
        local shooterPos = OWNER.Character.HumanoidRootPart.Position
        local targetPos = targetHead.Position

        if Conf["Value"]["BulletMethod"] == "Da Hood Legacy" then
            game:GetService("ReplicatedStorage").MainEvent:FireServer(
                "ShootGun",
                gunHandle,
                shooterPos,
                targetPos,
                targetHead,
                Vector3.new(0, 0, -1)
            )

        elseif Conf["Value"]["BulletMethod"] == "Hidden Bullet" then
            game:GetService("ReplicatedStorage").MainEvent:FireServer(
                "ShootGun",
                gunHandle,
                shooterPos - Vector3.new(0, 10, 0),
                targetPos - Vector3.new(0, 10, 0),
                targetHead,
                Vector3.new(0, 0, -1)
            )

        elseif Conf["Value"]["BulletMethod"] == "Chinese" then
            local randomOffset1 = math.random(-12, 12)
            local randomOffset2 = math.random(-12, 12)
            local randomOffset3 = math.random(-12, 12)

            game:GetService("ReplicatedStorage").MainEvent:FireServer(
                "ShootGun",
                gunHandle,
                shooterPos - Vector3.new(randomOffset2, randomOffset1, randomOffset2),
                targetPos - Vector3.new(randomOffset2, randomOffset2, randomOffset2),
                targetHead,
                Vector3.new(0, 0, -1)
            )

        elseif Conf["Value"]["BulletMethod"] == "Circle" then
            local radius = 5 -- Radius of the circle
            local angleIncrement = (2 * math.pi) / 8 -- Divide the circle into 8 points
            for i = 1, 8 do
                local angle = angleIncrement * i
                local offset = Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
                game:GetService("ReplicatedStorage").MainEvent:FireServer(
                    "ShootGun",
                    gunHandle,
                    shooterPos + offset,
                    targetPos + offset,
                    targetHead,
                    Vector3.new(0, 0, -1)
                )
            end

        elseif Conf["Value"]["BulletMethod"] == "Pentis" then
            local offsetBelowHRP = Vector3.new(0, -2, 0)
            game:GetService("ReplicatedStorage").MainEvent:FireServer(
                "ShootGun",
                gunHandle,
                shooterPos,
                targetHRP.Position + offsetBelowHRP,
                targetHead,
                Vector3.new(0, 0, -1)
            )

        else
            game:GetService("ReplicatedStorage").MainEvent:FireServer(
                "ShootGun",
                gunHandle,
                shooterPos,
                targetPos,
                targetHead,
                Vector3.new(0, 0, -1)
            ) 
        end
    end
end

