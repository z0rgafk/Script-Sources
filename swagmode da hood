function gclosest()
    local closestPlayer
    local shortestDistance = math.huge
    for i, v in game:FindService("Players"):GetPlayers() do
        if v ~= OWNER and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 and v.Character:FindFirstChild("HumanoidRootPart") then
            local pos = workspace.CurrentCamera:WorldToViewportPoint(v.Character.Head.Position)
            local magnitude = (Vector2.new(pos.X, pos.Y) - Vector2.new(OWNER:GetMouse().X, OWNER:GetMouse().Y)).magnitude
            if magnitude < shortestDistance then
                closestPlayer = v
                shortestDistance = magnitude
            end
        end
    end
    return closestPlayer
end

