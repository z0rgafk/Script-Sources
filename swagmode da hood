	end
	if getgenv().ToolCACache[name] then
		getgenv().ToolCACache[name]:Disconnect()
		getgenv().ToolCACache[name]=nil
	end
	local Tool
	function tools()
		Tool = Instance.new("Tool",OWNER.Backpack)
		Tool.Name = name 
		Tool.RequiresHandle = false 
		getgenv().ToolCache[name]=Tool.Activated:Connect(function()
